{
  "app_name": "StaffAny Hermes Data Bot",
  "app_slug": "hermes-data-bot",
  "kind": "hermes-runtime-app",
  "canonical": true,
  "runtime": "Hermes Agent",
  "profile_name": "staffanydatabot",
  "rollout_stage": "Slack POC in #da-ta-hermz-testing",
  "model_provider": "anthropic",
  "model": "claude-sonnet-4-6",
  "paths": {
    "soul": "profile/SOUL.md",
    "config_template": "profile/config.template.yaml",
    "skill": "skills/staffany-data-bot/SKILL.md",
    "google_sheets_output_skill": "../hermes-shared/google-sheets-output/skills/staffany-google-sheets-output/SKILL.md",
    "references": [
      "skills/staffany-data-bot/references/staffany-data-bot-metric-registry.md",
      "skills/staffany-data-bot/references/staffany-product-lookup-registry.md",
      "skills/staffany-data-bot/references/staffany-release-feature-registry.md",
      "skills/staffany-data-bot/references/rbac-access-levels.md",
      "skills/staffany-data-bot/references/reviewed-lessons.md",
      "skills/staffany-data-bot/references/regression-cases.md"
    ],
    "bigquery_mcp": "runtime/mcp/staffany-bigquery.md",
    "jira_release_sync": "runtime/jira-release-sync.md",
    "jira_release_sync_script": "runtime/sync-jira-release-registry.sh",
    "feature_usage_digest": "runtime/high-priority-feature-digest.md",
    "feature_usage_digest_prompt": "runtime/prompts/high-priority-feature-usage-digest.md",
    "memory_honcho": "runtime/memory-honcho.md",
    "slack_runtime": "runtime/slack.md",
    "slack_allowlist_update_script": "runtime/update-slack-allowlist.sh",
    "slack_context_mcp": "runtime/mcp/staffany_slack_context_server.py",
    "c360_mcp": "runtime/mcp/staffany_c360_server.py",
    "data_learning_mcp": "runtime/mcp/staffany_data_learning_server.py",
    "data_learning_report_script": "runtime/report-staffany-data-learning.py",
    "google_sheets_output_runtime": "../hermes-shared/google-sheets-output/runtime/google-sheets-output.md",
    "google_sheets_output_mcp": "../hermes-shared/google-sheets-output/runtime/mcp/staffany_google_sheets_server.py",
    "google_sheets_output_oauth_helper": "../hermes-shared/google-sheets-output/runtime/mcp/google_oauth.py",
    "health_checks": "runtime/health-checks.md",
    "health_check_script": "runtime/check-health.sh",
    "cloud_heartbeat_script": "runtime/check-cloud-heartbeat.sh",
    "cloud_doctor_script": "runtime/staffanydatabot-cloud-doctor.sh",
    "live_profile_audit_script": "runtime/audit-live-profile.sh",
    "honcho_backup_script": "runtime/backup-honcho.sh",
    "honcho_memory_review_script": "runtime/review-honcho-memory.sh",
    "gcp_vm_topology": "deploy/gcp-vm-topology.md",
    "deploy_runbook": "deploy/gce-onboarding-runbook.md",
    "regression_cases": "tests/regression-cases.md",
    "prompt_evals": "tests/prompt-evals.json"
  },
  "mcp": {
    "server_name": "staffany_bigquery",
    "url": "https://bq-mcp-proxy-1093387803298.asia-southeast1.run.app/mcp",
    "auth_env_var": "MCP_STAFFANY_BIGQUERY_API_KEY",
    "expected_tools": [
      "list_dataset_ids",
      "list_table_ids",
      "get_table_info",
      "execute_sql_readonly"
    ]
  },
  "slack_context_mcp": {
    "server_name": "staffany_slack_context",
    "auth_env_var": "SLACK_BOT_TOKEN",
    "configured_channel_ids_env": "STAFFANY_DATA_BOT_SLACK_CONTEXT_CHANNEL_IDS",
    "fallback_channel_ids_env": "SLACK_HOME_CHANNEL",
    "expected_tools": [
      "get_current_slack_thread_context",
      "get_selected_slack_thread_context"
    ],
    "read_only": true,
    "posts_to_slack": false,
    "uses_user_token": false,
    "uses_slack_connector": false
  },
  "c360_mcp": {
    "server_name": "staffany_c360",
    "base_url_env_var": "CUSTOMER360_BASE_URL",
    "auth_env_var": "CUSTOMER360_INTERNAL_API_TOKEN",
    "auth_header": "X-Customer360-Internal-Token",
    "expected_tools": [
      "list_current_customer_orgs"
    ],
    "read_only": true,
    "uses_browser_cookie": false,
    "uses_personal_customer360_session": false
  },
  "data_learning_mcp": {
    "server_name": "staffany_data_learning",
    "candidates_dir_env": "STAFFANY_DATA_LEARNING_CANDIDATES_DIR",
    "default_candidates_dir": "~/.hermes/profiles/staffanydatabot/runtime/lesson-candidates",
    "expected_tools": [
      "record_staffany_data_lesson_candidate",
      "list_staffany_data_lesson_candidates",
      "read_staffany_data_lesson_candidate",
      "update_staffany_data_lesson_candidate_status"
    ],
    "review_status_tool": "update_staffany_data_lesson_candidate_status",
    "review_approval_marker": "human reviewed lesson",
    "valid_statuses": [
      "pending_review",
      "needs_more_evidence",
      "approved_for_repo_promotion",
      "rejected",
      "promoted"
    ],
    "writes_runtime_candidates_only": true,
    "active_behavior_change": false,
    "self_approval": false,
    "honcho_source_of_truth": false,
    "stores_raw_slack_transcripts": false,
    "stores_raw_query_rows": false,
    "stores_sensitive_data": false
  },
  "data_learning_review_report": {
    "script": "runtime/report-staffany-data-learning.py",
    "mode": "no_agent_script",
    "prints_safe_counts_only": true,
    "prints_raw_lesson_content": false,
    "stale_threshold_days_default": 14
  },
  "google_sheets_output_mcp": {
    "server_name": "staffany_google_sheets",
    "account_email": "team@staffany.com",
    "access_mode": "team_oauth_google_sheets_output",
    "service_account": false,
    "auth_env_vars": [
      "GOOGLE_SHEETS_TOKEN_FILE",
      "GOOGLE_SHEETS_CLIENT_SECRET_FILE",
      "GOOGLE_SHEETS_ACCOUNT_EMAIL",
      "GOOGLE_SHEETS_OUTPUT_FOLDER_ID",
      "GOOGLE_SHEETS_OUTPUT_SHARE_EMAILS"
    ],
    "required_scopes": [
      "https://www.googleapis.com/auth/spreadsheets",
      "https://www.googleapis.com/auth/drive.file"
    ],
    "expected_tools": [
      "check_google_sheets_output_access",
      "create_spreadsheet_from_rows"
    ],
    "read_only_source_data": true,
    "create_only": true,
    "edits_existing_spreadsheets": false,
    "uses_user_token": false,
    "uses_slack_connector": false,
    "requires_output_folder_or_share_target": true,
    "limits": {
      "max_tabs": 5,
      "max_rows_per_tab": 5000,
      "max_total_cells": 100000,
      "max_cell_chars": 2000
    },
    "formula_like_cells_escaped": true
  },
  "channels": [
    "Slack #da-ta-hermz-testing"
  ],
  "secrets_copied": false,
  "legacy_sources": [
    "agents/hermes-data-bot/versions/2026-05-08T002500Z",
    "agents/data-bot/versions/2026-04-30T090405Z"
  ]
}
