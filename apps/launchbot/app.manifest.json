  "required_env_names": [
    "SLACK_BOT_TOKEN",
    "JIRA_BASE_URL",
    "JIRA_EMAIL",
    "JIRA_API_TOKEN",
    "LAUNCHBOT_KER_ALLOWED_CHANNEL_IDS"
