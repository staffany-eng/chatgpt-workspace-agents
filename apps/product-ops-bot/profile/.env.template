# Product Ops Bot runtime env template (no real secrets here).
# Copy values into ~/.hermes/profiles/productopsbot/.env and ~/.hermes/.env as needed.

# Slack runtime
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
GATEWAY_ALLOW_ALL_USERS=true
# SLACK_ALLOWED_USERS=U01234567,U089ABCDE
# SLACK_HOME_CHANNEL=C0123456789

# Model provider
ANTHROPIC_API_KEY=

# Jira integration (required for full workflow mode)
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
# Optional Jira custom field ids for RICE component sync
# JIRA_FIELD_REACH=customfield_xxxxx
# JIRA_FIELD_IMPACT=customfield_xxxxx
# JIRA_FIELD_CONFIDENCE=customfield_xxxxx
# JIRA_FIELD_EFFORT=customfield_xxxxx
# JIRA_FIELD_RICE_SCORE=customfield_xxxxx
# JIRA_FIELD_RICE_RATIONALE=customfield_xxxxx
# JIRA_FIELD_NEED_PRODUCT_REVIEW=customfield_10843

# Notion integration (required for full workflow mode)
NOTION_API_KEY=
# Keep default unless explicitly changed by Notion API version migration
NOTION_VERSION=2022-06-28
