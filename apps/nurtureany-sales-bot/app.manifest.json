    "access_policy_template": "runtime/access-policy.template.json",
    "bigquery_runtime": "runtime/bigquery.md",
    "google_calendar_runtime": "runtime/google-calendar.md",
    "google_calendar_mcp": "runtime/mcp/google_calendar_nurtureany_server.py",
