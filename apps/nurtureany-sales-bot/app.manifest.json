      "eugene@staffany.com",
      "kaiyi@staffany.com"
    ],
    "regional_managers": [
      {
        "email": "kerren.fong@staffany.com",
        "countries": [
          "Singapore",
          "Malaysia"
        ]
      },
      {
        "email": "sarah@staffany.com",
        "countries": [
          "Indonesia"
        ]
      }
    ]
  },
  "access_policy": {
    "runtime_env_var": "NURTUREANY_ACCESS_POLICY_PATH",
    "template": "runtime/access-policy.template.json",
    "owner_mapping_source": "hubspot_owners_api",
    "unclassified_hubspot_owners": "blocked",
    "sales_rep_scope": "own_hubspot_target_accounts_only",
    "manager_scope": "country_scoped_team_read_only",
    "full_roster_committed": false
  },
  "hubspot": {
    "source_of_truth": true,
    "target_account_property": "hs_is_target_account",
    "owner_property": "hubspot_owner_id",
    "country_property": "company_country",
    "country_values": [
      "Singapore",
      "Malaysia",
      "Indonesia"
    ],
    "company_properties": [
      "hs_is_target_account",
      "hubspot_owner_id",
      "company_country",
      "numberofemployees",
      "industry",
      "contract_end_date",
      "current_tool_renewal_date",
      "notes_last_updated",
      "hs_num_decision_makers",
      "hs_num_contacts_with_buying_roles",
      "prospecting_account"
    ],
    "contact_properties": [
      "email",
      "firstname",
      "lastname",
      "jobtitle",
      "job_role",
      "hs_buying_role",
      "hubspot_owner_id",
      "lastmodifieddate"
    ],
    "task_properties": [
      "hs_timestamp",
      "hs_task_subject",
      "hubspot_owner_id",
      "hs_task_status",
      "hs_task_priority",
      "hs_task_type",
      "hs_lastmodifieddate"
    ]
  },
  "tools": {
    "read": [
      "list_my_target_accounts",
      "list_team_target_accounts",
      "audit_hubspot_owner_roster",
      "get_account_context",
      "list_sales_followup_tasks",
      "score_nurture_accounts",
      "find_contact_gaps",
      "generate_free_search_tasks",
      "review_public_enrichment_evidence",
      "draft_nurture_message",
      "list_google_calendar_events",
      "list_luma_events",
      "get_luma_event_context",
      "search_exa_people_candidates",
      "search_lusha_decision_maker_candidates",
      "get_lusha_credit_usage"
    ],
    "preview": [
      "plan_hubspot_writeback"
    ],
    "approval_gated_enrichment": [
      "reveal_lusha_contact_details"
    ],
    "mutation_requires_explicit_approval": [
      "create_hubspot_task",
      "append_hubspot_note",
      "update_nurture_fields"
    ]
  },
  "lusha": {
    "auth_env_var": "LUSHA_API_KEY",
    "max_search_companies": 5,
    "max_candidates_per_company": 5,
    "max_reveal_contacts": 3,
    "selected_pii_in_slack": true,
    "bulk_contact_exports": false,
    "hubspot_writeback": "preview_only"
  },
  "exa": {
    "auth_env_var": "EXA_API_KEY",
    "max_search_companies": 5,
    "max_candidates_per_company": 5,
    "selected_pii_in_slack": false,
    "bulk_contact_exports": false,
    "hubspot_writeback": "none",
    "allowed_endpoint": "POST /search",
    "category": "people"
  },
  "google_calendar": {
    "account_email": "team@staffany.com",
    "auth_env_vars": [
      "GOOGLE_CALENDAR_TOKEN_FILE",
      "GOOGLE_CALENDAR_CLIENT_SECRET_FILE",
      "GOOGLE_CALENDAR_ACCOUNT_EMAIL"
    ],
    "required_scope": "https://www.googleapis.com/auth/calendar.readonly",
    "read_only": true,
    "max_calendars": 5,
    "max_events_per_calendar": 50,
    "allowed_tools": [
      "list_google_calendar_events"
    ],
    "event_mutations": false,
    "attendee_exports": false
  },
  "luma": {
    "auth_env_var": "LUMA_API_KEY",
    "base_url": "https://public-api.luma.com",
    "read_only": true,
    "max_events": 50,
    "default_event_limit": 20,
    "max_events_for_context": 20,
    "max_guests_per_event": 250,
    "attendance_definition": "checked_in_at_present",
    "country_tags": [
      "Singapore",
      "Malaysia",
      "Indonesia"
    ],
    "location_tags": [
      "Singapore",
      "Jakarta",
      "Bali",
      "Kuala Lumpur"
    ],
    "location_tag_country_map": {
      "Singapore": "Singapore",
      "Jakarta": "Indonesia",
      "Bali": "Indonesia",
      "Kuala Lumpur": "Malaysia"
    },
    "event_type_tags": [
      "Sports",
      "Appreciation Afternoon",
      "HR Happy Hour",
      "Leaders Lounge"
    ],
    "preferred_event_filter": "event_tags",
    "allowed_tools": [
      "list_luma_events",
      "get_luma_event_context"
    ],
    "requires_scoped_hubspot_companies": true,
    "raw_attendee_exports": false,
    "event_mutations": false,
    "hubspot_writeback": "none"
  },
  "external_message_sending": false,
  "honcho_enabled": false,
  "secrets_copied": false,
