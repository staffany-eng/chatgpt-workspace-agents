{
  "schema_version": 1,
  "app": "nurtureany-sales-bot",
  "bot": "NurtureAny Sales Bot",
  "runtime_model": {
    "provider": "anthropic",
    "model": "claude-sonnet-4-6",
    "effort_policy": {
      "static": "low",
      "tool-trace": "medium",
      "answer-contract": "medium",
      "live-smoke": "medium"
    },
    "effort_config_status": "documented_policy_only_no_verified_hermes_anthropic_effort_knob"
  },
  "codex_operator_checks": {
    "must_read": [
      "AGENTS.md",
      "apps/nurtureany-sales-bot/AGENTS.md",
      "apps/nurtureany-sales-bot/profile/SOUL.md",
      "apps/nurtureany-sales-bot/runtime/slack.md"
    ],
    "must_run": [
      "node scripts/run-prompt-evals.mjs --app nurtureany-sales-bot --mode all",
      "npm run nurtureany-sales-bot:verify"
    ]
  },
  "evals": [
    {
      "id": "nurtureany-static-sg-lead-enrichment-route",
      "bot": "NurtureAny Sales Bot",
      "surface": "slack",
      "lane": "static",
      "input": "@NurtureAny build Singapore lead enrichment plan for Jeremy's fixed account list, compact sample",
      "setup": {
        "first_slack_mention": true,
        "live_tools": "disabled"
      },
      "expected_tool_trace": {
        "must_call_after_run": [
          "build_singapore_lead_enrichment_plan"
        ],
        "must_not_call": [
          "find_contact_gaps",
          "score_nurture_accounts",
          "generate_free_search_tasks"
        ]
      },
      "expected_answer_contract": {
        "must_include": [
          "Interpreted question:",
          "Reply \"run\" to start, or tell me what to change."
        ],
        "must_not_include": [
          "Answer:"
        ]
      },
      "forbidden_behavior": [
        "find_contact_gaps",
        "score_nurture_accounts",
        "raw phone-number export",
        "WhatsApp send"
      ],
      "grade_notes": "First response must plan the SG orchestrator. The compact/smoke wording does not permit a wrong shortcut.",
      "assertions": {
        "source_files": [
          {
            "path": "profile/SOUL.md",
            "must_contain": [
              "MUST plan and run `build_singapore_lead_enrichment_plan`",
              "Do not route these prompts through `find_contact_gaps`, `score_nurture_accounts`, `generate_free_search_tasks`, Exa, or Lusha directly",
              "output_mode=\"compact\""
            ]
          },
          {
            "path": "tests/regression-cases.md",
            "must_contain": [
              "After `run`, calls `build_singapore_lead_enrichment_plan` with `owner_email=jeremy.wong@staffany.com`"
            ]
          }
        ]
      }
    },
    {
