{
  "app_name": "PSM Ops Hermes Bot",
  "app_slug": "psm-ops-bot",
  "kind": "hermes-runtime-app",
  "canonical": true,
  "runtime": "Hermes Agent",
  "profile_name": "psmopsbot",
  "rollout_stage": "Slack open-channel enabled",
  "model_provider": "anthropic",
  "model": "claude-sonnet-4-6",
  "cloud": {
    "project": "staffany-warehouse",
    "region": "asia-southeast1",
    "zone": "asia-southeast1-a",
    "vm_name": "hermes-psm-ops-bot-poc",
    "gateway_service": "hermes-gateway-psmopsbot.service"
  },
  "paths": {
    "soul": "profile/SOUL.md",
    "config_template": "profile/config.template.yaml",
    "skill": "skills/psm-ops-bot/SKILL.md",
    "references": [
      "skills/psm-ops-bot/references/jira-field-contract.md",
      "skills/psm-ops-bot/references/customer-channel-candidates.md",
      "skills/psm-ops-bot/references/regression-cases.md"
    ],
    "jira_runtime": "runtime/jira.md",
    "c360_runtime": "runtime/c360.md",
    "google_calendar_runtime": "runtime/google-calendar.md",
    "slack_runtime": "runtime/slack.md",
    "psm_jira_mcp": "runtime/mcp/psm_jira_server.py",
    "psm_c360_mcp": "runtime/mcp/psm_c360_server.py",
    "psm_google_calendar_mcp": "runtime/mcp/psm_google_calendar_server.py",
    "health_checks": "runtime/health-checks.md",
    "health_check_script": "runtime/check-health.sh",
    "cloud_heartbeat_script": "runtime/check-cloud-heartbeat.sh",
    "live_profile_audit_script": "runtime/audit-live-profile.sh",
    "rock_productions_c360_smoke_script": "runtime/smoke-rock-productions-c360.sh",
    "adoption_digest_script": "runtime/psm_ops_adoption_digest.py",
    "due_date_reminder_script": "runtime/scripts/psm_ops_due_date_reminders.py",
    "roi_tracker_sync_script": "runtime/scripts/psm_ops_roi_tracker_sync.py",
    "slack_notifier": "runtime/mcp/psm_slack_notifier.py",
    "adoption_hook": "runtime/hooks/psm-ops-adoption-telemetry/HOOK.yaml",
    "adoption_hook_handler": "runtime/hooks/psm-ops-adoption-telemetry/handler.py",
    "deploy_runbook": "deploy/gce-onboarding-runbook.md",
    "regression_cases": "tests/regression-cases.md",
    "prompt_evals": "tests/prompt-evals.json"
  },
  "mcp": {
    "psm_jira": {
      "command_env": "PSM_OPS_PYTHON",
      "expected_tools": [
        "validate_jira_configuration",
        "validate_roi_jira_configuration",
        "resolve_slack_user_identity",
        "classify_roi_ticket_request",
        "resolve_customer_channel_org",
        "list_my_pco_tasks",
        "find_ticket_by_slack_thread",
        "find_roi_ticket_by_slack_thread",
        "create_roi_ticket_from_slack",
        "create_or_link_pco_roi_tracker",
        "create_ps_wee_intake_ticket",
        "append_ps_wee_ticket_update",
        "mark_ps_wee_ticket_ready",
        "draft_pco_task",
        "create_approved_pco_task",
        "transition_pco_task",
        "add_internal_pco_comment",
        "set_pco_assignee",
        "set_pco_ps_team",
        "link_pco_to_engineering_issue",
        "set_pco_reminder",
        "list_due_pco_reminders"
      ]
    },
    "psm_c360": {
      "command_env": "PSM_OPS_PYTHON",
      "expected_tools": [
        "search_c360_customers",
        "get_c360_account_context",
        "ask_c360_customer_context"
      ]
    },
    "psm_google_calendar": {
      "command_env": "PSM_OPS_PYTHON",
      "expected_tools": [
        "read_customer_calendar_context"
      ]
    }
  },
  "jira": {
    "project_key": "PCO",
    "source_of_truth": true,
    "task_owner_field": "PS Team",
    "task_owner_field_id": "customfield_10876",
    "slack_identity_strategy": "users.list profile email/name automatch to PS Team",
    "status_names": [
      "Open",
      "Waiting Customer",
      "Waiting Internal",
      "Scheduled",
      "Done",
      "Cancelled"
    ],
    "field_config_required": true,
    "public_comments_default": false,
    "roi_direct": {
      "source_of_truth": true,
      "project_key_env_var": "PSM_OPS_ROI_JIRA_PROJECT_KEY",
      "service_desk_id_env_var": "PSM_OPS_ROI_JIRA_SERVICE_DESK_ID",
      "request_type_id_env_var": "PSM_OPS_ROI_JIRA_REQUEST_TYPE_ID",
      "requester_rule": "explicit requested/reported-by wins, otherwise current Slack sender; unresolved requester blocks creation",
      "idempotency_key": "Slack thread permalink",
      "pco_tracker": {
        "default_for_ps_team_billing": true,
        "label": "ps-wee-roi-tracker",
        "status": "Waiting Internal",
        "sync_cron": "*/30 1-10 * * 1-5"
      },
      "field_envs": [
        "PSM_OPS_ROI_JIRA_FIELD_CUSTOMER",
        "PSM_OPS_ROI_JIRA_FIELD_STAFFANY_ORGS",
        "PSM_OPS_ROI_JIRA_FIELD_REQUEST_CATEGORY",
        "PSM_OPS_ROI_JIRA_FIELD_SOURCE_LINKS",
        "PSM_OPS_ROI_JIRA_FIELD_REQUESTER",
        "PSM_OPS_ROI_JIRA_FIELD_REQUESTER_SLACK",
        "PSM_OPS_ROI_JIRA_FIELD_ORIGINAL_CHANNEL",
        "PSM_OPS_ROI_JIRA_FIELD_PRIORITY"
      ]
    }
  },
  "customer360": {
    "source_of_truth": true,
    "all_customer_access_v1": true,
    "auth_env_var": "CUSTOMER360_INTERNAL_API_TOKEN",
    "base_url_env_var": "CUSTOMER360_BASE_URL"
  },
  "google_calendar": {
    "account_email": "team@staffany.com",
    "access_mode": "team_oauth_shared_calendar",
    "service_account": false,
    "required_scope": "https://www.googleapis.com/auth/calendar.readonly",
    "read_only": true,
    "max_calendars": 5,
    "max_events_per_calendar": 50,
    "allowed_tools": [
      "read_customer_calendar_context"
    ],
    "event_mutations": false,
    "attendee_exports": false,
    "private_field_exports": false
  },
  "channels": [
    "Slack public/open channels with mention-required gateway"
  ],
  "central_audit": {
    "slack_channel_name": "ps-weeman-bot-test",
    "slack_channel_id_env_var": "PSM_OPS_CENTRAL_SLACK_CHANNEL_ID",
    "reminder_mention_map_env_var": "PSM_OPS_REMINDER_MENTION_MAP_PATH",
    "message_prefix": "PSM Ops automation:",
    "events": [
      "ticket_created",
      "ticket_reused",
      "roi_ticket_created",
      "roi_ticket_reused",
      "roi_tracker_linked",
      "roi_tracker_sync",
      "ticket_update_synced",
      "ticket_ready",
      "blocked",
      "c360_search",
      "c360_account_context",
      "c360_customer_answer",
      "c360_blocked"
    ]
  },
  "secrets_copied": false
}
