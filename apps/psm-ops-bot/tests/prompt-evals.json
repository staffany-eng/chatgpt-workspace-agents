{
  "schema_version": 1,
  "app": "psm-ops-bot",
  "bot": "PSM Ops Hermes Bot",
  "runtime_model": {
    "provider": "anthropic",
    "model": "claude-sonnet-4-6",
    "effort_policy": {
      "static": "low",
      "tool-trace": "medium",
      "answer-contract": "medium",
      "live-smoke": "medium"
    },
    "effort_config_status": "documented_policy_only_no_verified_hermes_anthropic_effort_knob"
  },
  "codex_operator_checks": {
    "must_read": [
      "AGENTS.md",
      "apps/psm-ops-bot/AGENTS.md",
      "apps/psm-ops-bot/profile/SOUL.md",
      "apps/psm-ops-bot/runtime/slack.md"
    ],
    "must_run": [
      "node scripts/run-prompt-evals.mjs --app psm-ops-bot --mode all",
      "npm run psm-ops-bot:verify"
    ]
  },
  "evals": [
    {
      "id": "psm-static-ps-wee-alias-existing-bot",
      "bot": "PSM Ops Hermes Bot",
      "surface": "slack",
      "lane": "static",
      "input": "@PS WEE what are you / help me with this customer ops task",
      "setup": {
        "first_slack_mention": true,
        "live_tools": "disabled"
      },
      "expected_tool_trace": {
        "must_call": []
      },
      "expected_answer_contract": {
        "must_include": [
          "PSM Ops",
          "Source:",
          "Scope:",
          "Confidence:",
          "Caveat:"
        ],
        "must_not_include": [
          "new bot",
          "new profile",
          "NurtureAny"
        ]
      },
      "forbidden_behavior": [
        "route PS WEE to a new app",
        "route PS WEE to NurtureAny",
        "guess a new profile"
      ],
      "grade_notes": "PS WEE and PS Wee Manager are aliases for psmopsbot only.",
      "assertions": {
        "source_files": [
          {
            "path": "profile/SOUL.md",
            "must_contain": [
              "Alias rule: PS WEE, PS Wee Manager, and PSM Manager Ops Bot all mean this PSM Ops Bot.",
              "Do not route those names to a new bot/profile."
            ]
          },
          {
            "path": "tests/regression-cases.md",
            "must_contain": [
              "PS WEE Ticket First",
              "Treats PS WEE as the existing PSM Ops Bot."
            ]
          }
        ]
      }
    },
    {
      "id": "psm-tooltrace-ticket-first-intake",
      "bot": "PSM Ops Hermes Bot",
      "surface": "slack:#ps-weeman-bot-test",
      "lane": "tool-trace",
      "input": "@PS WEE create a ticket for this customer issue from this thread",
      "setup": {
        "after_user_request": true,
        "stub_tools": true
      },
      "expected_tool_trace": {
        "must_call": [
          "find_ticket_by_slack_thread",
          "create_ps_wee_intake_ticket"
        ],
        "must_not_call": [
          "draft_pco_task",
          "create_approved_pco_task"
        ],
        "argument_shape": {
          "slack_thread_permalink": "required",
          "missing_fields_allowed": true
        }
      },
      "expected_answer_contract": {
        "must_include": [
          "Source:",
          "Scope:",
          "Confidence:",
          "Caveat:"
        ]
      },
      "forbidden_behavior": [
        "preview-first for explicit PS WEE ticketing",
        "ask do you want me to log a ticket first",
        "create duplicate same-thread ticket"
      ],
      "grade_notes": "Explicit PS WEE ticketing is ticket-first: dedupe by Slack thread, then create the needs-info intake immediately.",
      "assertions": {
        "source_files": [
          {
            "path": "runtime/slack.md",
            "must_contain": [
              "PS WEE ticketing requests are ticket-first.",
              "create the PCO intake ticket immediately if no ticket already exists for the same Slack thread permalink"
            ]
          },
          {
            "path": "tests/regression-cases.md",
            "must_contain": [
              "Calls `find_ticket_by_slack_thread`.",
              "Creates the PCO intake ticket immediately with `create_ps_wee_intake_ticket` when no same-thread ticket exists."
            ]
          }
        ]
      }
    },
    {
      "id": "psm-tooltrace-tomoro-compact-missing-info",
      "bot": "PSM Ops Hermes Bot",
      "surface": "slack:#all-ps",
      "lane": "tool-trace",
      "input": "@PS WEE please create a ticket for CS to follow up regarding Tomoro Coffee unable to add staff in HRAny. Same phone number is linked to affected staff HUI SHAN WENG in inactive I LOVE TAIMEI; they need workaround advice.",
      "setup": {
        "after_user_request": true,
        "stub_tools": true
      },
      "expected_tool_trace": {
        "must_call": [
          "find_ticket_by_slack_thread",
          "create_ps_wee_intake_ticket"
        ],
        "must_not_call": [
          "draft_pco_task",
          "create_approved_pco_task"
        ],
        "argument_shape": {
          "slack_thread_permalink": "required",
          "known_facts_required": true,
          "slack_missing_info_max": 2
        }
      },
      "expected_answer_contract": {
        "must_include": [
          "Source: Jira PCO",
          "Confidence:"
        ],
        "must_not_include": [
          "1. *Customer/org*",
          "2. *Affected outlet/user*",
          "3. *Impact/urgency*",
          "4. *Expected outcome*",
          "5. *Due date*"
        ]
      },
      "forbidden_behavior": [
        "numbered follow-up questionnaire",
        "asking for customer/org when customer was supplied",
        "asking for issue details when issue_summary or known_details was supplied",
        "more than two Slack-facing missing-info asks"
      ],
      "grade_notes": "Tomoro-style intake should still create first, but the tool must prune known facts and keep Slack missing-info compact.",
      "assertions": {
        "source_files": [
          {
            "path": "runtime/mcp/psm_jira_server.py",
            "must_contain": [
              "PS_WEE_SLACK_MISSING_INFO_LIMIT = 2",
              "answer[\"missing_info\"] = slack_missing"
            ]
          },
          {
            "path": "profile/SOUL.md",
            "must_contain": [
              "Do not add numbered questionnaires or expand the missing-info list; ask only the tool-returned missing fields."
            ]
          }
        ]
      }
    },
    {
      "id": "psm-tooltrace-nearby-mention-to-ps-team",
      "bot": "PSM Ops Hermes Bot",
      "surface": "slack:#ft-hrany-documents-signatures-onboarding",
      "lane": "tool-trace",
      "input": "<@U0A6RLTV5EG> can we have a training for HRAny for PS team so they are equipped to onboard? cc @PS WEE help to track this and tag to barra",
      "setup": {
        "after_user_request": true,
        "stub_tools": true,
        "nearby_slack_mentions": [
          {
            "mention": "<@U0A6RLTV5EG>",
            "real_name": "Ahmad Nur Barraza",
            "ps_team": "Barra"
          }
        ]
      },
      "expected_tool_trace": {
        "must_call": [
          "resolve_slack_user_identity",
          "find_ticket_by_slack_thread",
          "create_ps_wee_intake_ticket"
        ],
        "must_not_call": [
          "set_pco_assignee"
        ],
        "argument_shape": {
          "resolved_identity_query": "<@U0A6RLTV5EG>",
          "create_ps_wee_intake_ticket.ps_team": "Barra"
        }
      },
      "expected_answer_contract": {
        "must_include": [
          "Source: Jira PCO",
          "Confidence:"
        ],
        "must_not_include": [
          "tag them with a Slack mention",
          "Barra's Slack identity"
        ]
      },
      "forbidden_behavior": [
        "ask the user to tag Barra again when the thread already has the mention",
        "use Jira assignee for PS WEE intake ownership",
        "skip same-thread ticket idempotency"
      ],
      "grade_notes": "Nearby Slack mentions should resolve person shorthand for PS WEE intake and map to Jira PS Team when available.",
      "assertions": {
        "source_files": [
          {
            "path": "profile/SOUL.md",
            "must_contain": [
              "Nearby Slack mentions beat bare-name uncertainty.",
              "This is Jira `PS Team` ownership, not Jira assignee."
            ]
          },
          {
            "path": "runtime/mcp/psm_jira_server.py",
            "must_contain": [
              "answer[\"ps_team\"] = ps_team_option[\"value\"]",
              "answer[\"ps_team_option_id\"] = ps_team_option[\"id\"]"
            ]
          },
          {
            "path": "tests/regression-cases.md",
            "must_contain": [
              "PS WEE Nearby Mention To PS Team",
              "Creates or reuses the PCO intake ticket with `ps_team=\"Barra\"`."
            ]
          }
        ]
      }
    },
    {
      "id": "psm-tooltrace-roi-direct-ticket-first",
      "bot": "PSM Ops Hermes Bot",
      "surface": "slack",
      "lane": "tool-trace",
      "input": "@PS WEE add this renewal invoice / MRR mismatch issue to ROI",
      "setup": {
        "stub_tools": true
      },
      "expected_tool_trace": {
        "must_call": [
          "classify_roi_ticket_request",
          "find_roi_ticket_by_slack_thread",
          "create_roi_ticket_from_slack"
        ],
        "must_not_call": [
          "create_ps_wee_intake_ticket",
          "draft_pco_task"
        ]
      },
      "expected_answer_contract": {
        "must_include": [
          "Source: Jira ROI",
          "Confidence:"
        ]
      },
      "forbidden_behavior": [
        "PCO wrapper ticket for ROI-direct work",
        "team@staffany.com requester fallback",
        "bot requester fallback"
      ],
      "grade_notes": "ROI-direct requests go straight to ROI JSM with requester resolution and same-thread idempotency.",
      "assertions": {
        "source_files": [
          {
            "path": "profile/SOUL.md",
            "must_contain": [
              "ROI-direct requests are ticket-first.",
              "No bot, team, or team@staffany.com requester fallback is allowed."
            ]
          }
        ]
      }
    },
    {
      "id": "psm-answer-contract-ticket-created-fixture",
      "bot": "PSM Ops Hermes Bot",
      "surface": "slack",
      "lane": "answer-contract",
      "input": "stub: create_ps_wee_intake_ticket returned answer.slack_reply",
      "setup": {
        "stub_output": "ps_wee_ticket_created"
      },
      "expected_tool_trace": {
        "must_call": [
          "create_ps_wee_intake_ticket"
        ]
      },
      "expected_answer_contract": {
        "must_include": [
          "Source:",
          "Scope:",
          "Confidence: verified",
          "Caveat:"
        ]
      },
      "forbidden_behavior": [
        "rewrite Jira Slack link syntax",
        "raw Slack transcript",
        "raw C360 source pack"
      ],
      "grade_notes": "If the Jira tool returns answer.slack_reply, paste it first exactly, then add labelled source/scope/confidence/caveat.",
      "assertions": {
        "answer_fixture": {
          "output": "Created PCO ticket: <https://staffany.atlassian.net/browse/PCO-123|PCO-123>. Please add affected outlet and expected outcome.\nSource: Jira PCO\nScope: current Slack thread; PS WEE intake ticket\nConfidence: verified\nCaveat: Ticket is needs-info until the missing fields are added in this thread."
        },
        "source_files": [
          {
            "path": "profile/SOUL.md",
            "must_contain": [
              "if the Jira tool returns `answer.slack_reply`, paste that string exactly as the first line"
            ]
          }
        ]
      }
    },
    {
      "id": "psm-live-smoke-ticket-first-intake",
      "bot": "PSM Ops Hermes Bot",
      "surface": "slack:#ps-weeman-bot-test",
      "lane": "live-smoke",
      "input": "@PS WEE create a test intake ticket from this smoke thread with dummy customer context",
      "setup": {
        "requires_live_profile": "psmopsbot",
        "requires_bot_owned_readback": true,
        "writes_allowed": "explicit_ticket_smoke_only"
      },
      "expected_tool_trace": {
        "must_call": [
          "find_ticket_by_slack_thread",
          "create_ps_wee_intake_ticket"
        ]
      },
      "expected_answer_contract": {
        "must_include": [
          "Source: Jira PCO",
          "Confidence:"
        ]
      },
      "forbidden_behavior": [
        "human-token posting",
        "Slack connector write",
        "raw transcript leakage",
        "duplicate same-thread ticket"
      ],
      "grade_notes": "Run only as an approved ticket smoke because it writes Jira. Use bot-owned Slack reply and same-thread idempotency."
    }
  ]
}
