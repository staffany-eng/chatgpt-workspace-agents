{
  "schema_version": 1,
  "app": "psm-ops-bot",
  "bot": "PSM Ops Hermes Bot",
  "runtime_model": {
    "provider": "anthropic",
    "model": "claude-sonnet-4-6",
    "effort_policy": {
      "static": "low",
      "tool-trace": "medium",
      "answer-contract": "medium",
      "live-smoke": "medium"
    },
    "effort_config_status": "documented_policy_only_no_verified_hermes_anthropic_effort_knob"
  },
  "codex_operator_checks": {
    "must_read": [
      "AGENTS.md",
      "apps/psm-ops-bot/AGENTS.md",
      "apps/psm-ops-bot/profile/SOUL.md",
      "apps/psm-ops-bot/runtime/slack.md"
    ],
    "must_run": [
      "node scripts/run-prompt-evals.mjs --app psm-ops-bot --mode all",
      "npm run psm-ops-bot:verify"
    ]
  },
  "evals": [
    {
      "id": "psm-static-ps-wee-alias-existing-bot",
      "bot": "PSM Ops Hermes Bot",
      "surface": "slack",
      "lane": "static",
      "input": "@PS WEE what are you / help me with this customer ops task",
      "setup": {
        "first_slack_mention": true,
        "live_tools": "disabled"
      },
      "expected_tool_trace": {
        "must_call": []
      },
      "expected_answer_contract": {
        "must_include": [
          "PSM Ops",
          "Source:",
          "Scope:",
          "Confidence:",
          "Caveat:"
        ],
        "must_not_include": [
          "new bot",
          "new profile",
          "NurtureAny"
        ]
      },
      "forbidden_behavior": [
        "route PS WEE to a new app",
        "route PS WEE to NurtureAny",
        "guess a new profile"
      ],
      "grade_notes": "PS WEE and PS Wee Manager are aliases for psmopsbot only.",
      "assertions": {
        "source_files": [
          {
            "path": "profile/SOUL.md",
            "must_contain": [
              "Alias rule: PS WEE, PS Wee Manager, and PSM Manager Ops Bot all mean this PSM Ops Bot.",
              "Do not route those names to a new bot/profile."
            ]
          },
          {
            "path": "tests/regression-cases.md",
            "must_contain": [
              "PS WEE Ticket First",
              "Treats PS WEE as the existing PSM Ops Bot."
            ]
          }
        ]
      }
    },
    {
      "id": "psm-tooltrace-ticket-first-intake",
      "bot": "PSM Ops Hermes Bot",
      "surface": "slack:#ps-weeman-bot-test",
      "lane": "tool-trace",
      "input": "@PS WEE create a ticket for this customer issue from this thread",
      "setup": {
        "after_user_request": true,
        "stub_tools": true
      },
      "expected_tool_trace": {
        "must_call": [
          "find_ticket_by_slack_thread",
          "search_pco_tickets",
          "create_ps_wee_intake_ticket"
        ],
        "must_not_call": [
          "draft_pco_task",
          "create_approved_pco_task"
        ],
        "argument_shape": {
          "slack_thread_permalink": "required",
          "missing_fields_allowed": true
        }
      },
      "expected_answer_contract": {
        "must_include": [
          "Source:",
          "Scope:",
          "Confidence:",
          "Caveat:"
        ]
      },
      "forbidden_behavior": [
        "preview-first for explicit PS WEE ticketing",
        "ask do you want me to log a ticket first",
        "create duplicate same-thread ticket"
      ],
      "grade_notes": "Explicit PS WEE ticketing is ticket-first: dedupe by Slack thread, run bounded PCO board search as duplicate guard, then create the needs-info intake.",
      "assertions": {
        "source_files": [
          {
            "path": "runtime/slack.md",
            "must_contain": [
              "PS WEE ticketing requests are ticket-first.",
              "use `search_pco_tickets` as the broader duplicate guard"
            ]
          },
          {
            "path": "tests/regression-cases.md",
            "must_contain": [
              "Calls `find_ticket_by_slack_thread`.",
              "Calls `search_pco_tickets` before creating when no same-thread ticket exists."
            ]
          }
        ]
      }
    },
    {
      "id": "psm-tooltrace-pco-board-search-before-no-ticket",
      "bot": "PSM Ops Hermes Bot",
      "surface": "slack:#proj-cs-munchi",
      "lane": "tool-trace",
      "input": "@PS WEE are we already tracking this in PCO? Thread context: salaried staff without schedule/work for the month, full attendance, proration.",
      "setup": {
        "after_user_request": true,
        "stub_tools": true
      },
      "expected_tool_trace": {
        "must_call": [
          "search_pco_tickets"
        ],
        "must_not_call": [
          "create_ps_wee_intake_ticket",
          "draft_pco_task"
        ],
        "argument_shape": {
          "query_contains_thread_context": true,
          "safe_fields_only": true,
          "ambiguous_results_require_user_choice": true
        }
      },
      "expected_answer_contract": {
        "must_include": [
          "Source: Jira PCO",
          "Confidence:"
        ]
      },
      "forbidden_behavior": [
        "answer no PCO ticket found from exact Slack permalink search alone",
        "create duplicate PCO ticket",
        "expose raw Jira descriptions, comments, attachments, or bulk exports"
      ],
      "grade_notes": "PCO tracking checks use bounded board search, so manually-created tickets without Slack source links can still be found.",
      "assertions": {
        "source_files": [
          {
            "path": "runtime/mcp/psm_jira_server.py",
            "must_contain": [
              "def search_pco_tickets",
              "PCO_SEARCH_DOMAIN_TERMS"
            ]
          },
          {
            "path": "runtime/slack.md",
            "must_contain": [
              "PCO tracking checks must use `search_pco_tickets` before saying no PCO ticket exists."
            ]
          }
        ]
      }
    },
    {
      "id": "psm-tooltrace-tomoro-compact-missing-info",
      "bot": "PSM Ops Hermes Bot",
      "surface": "slack:#all-ps",
      "lane": "tool-trace",
      "input": "@PS WEE please create a ticket for CS to follow up regarding Tomoro Coffee unable to add staff in HRAny. Same phone number is linked to affected staff HUI SHAN WENG in inactive I LOVE TAIMEI; they need workaround advice.",
      "setup": {
        "after_user_request": true,
        "stub_tools": true
      },
      "expected_tool_trace": {
        "must_call": [
          "find_ticket_by_slack_thread",
          "search_pco_tickets",
          "create_ps_wee_intake_ticket"
        ],
        "must_not_call": [
          "draft_pco_task",
          "create_approved_pco_task"
        ],
        "argument_shape": {
          "slack_thread_permalink": "required",
          "known_facts_required": true,
          "slack_missing_info_max": 2
        }
      },
      "expected_answer_contract": {
        "must_include": [
          "Source: Jira PCO",
          "Confidence:"
        ],
        "must_not_include": [
          "1. *Customer/org*",
          "2. *Affected outlet/user*",
          "3. *Impact/urgency*",
          "4. *Expected outcome*",
          "5. *Due date*"
        ]
      },
      "forbidden_behavior": [
        "numbered follow-up questionnaire",
        "asking for customer/org when customer was supplied",
        "asking for issue details when issue_summary or known_details was supplied",
        "more than two Slack-facing missing-info asks"
      ],
      "grade_notes": "Tomoro-style intake should still create first, but the tool must prune known facts and keep Slack missing-info compact.",
      "assertions": {
        "source_files": [
          {
            "path": "runtime/mcp/psm_jira_server.py",
            "must_contain": [
              "PS_WEE_SLACK_MISSING_INFO_LIMIT = 2",
              "answer[\"missing_info\"] = slack_missing"
            ]
          },
          {
            "path": "profile/SOUL.md",
            "must_contain": [
              "Do not add numbered questionnaires or expand the missing-info list; ask only the tool-returned missing fields."
            ]
          }
        ]
      }
    },
    {
      "id": "psm-tooltrace-roi-direct-ticket-first",
      "bot": "PSM Ops Hermes Bot",
      "surface": "slack",
      "lane": "tool-trace",
      "input": "@PS WEE add this renewal invoice / MRR mismatch issue to ROI",
      "setup": {
        "stub_tools": true
      },
      "expected_tool_trace": {
        "must_call": [
          "classify_roi_ticket_request",
          "find_roi_ticket_by_slack_thread",
          "create_roi_ticket_from_slack",
          "create_or_link_pco_roi_tracker"
        ],
        "must_not_call": [
          "create_ps_wee_intake_ticket",
          "draft_pco_task"
        ]
      },
      "expected_answer_contract": {
        "must_include": [
          "Source: Jira ROI",
          "Jira PCO tracker",
          "Confidence:"
        ]
      },
      "forbidden_behavior": [
        "duplicate PCO execution wrapper for ROI-direct work",
        "team@staffany.com requester fallback",
        "bot requester fallback"
      ],
      "grade_notes": "PS Team billing ROI-direct requests create/reuse ROI first, then add a linked PCO customer-loop tracker.",
      "assertions": {
        "source_files": [
          {
            "path": "profile/SOUL.md",
            "must_contain": [
              "ROI-direct requests are ticket-first.",
              "pco_tracker_default=true",
              "create_or_link_pco_roi_tracker",
              "No bot, team, or team@staffany.com requester fallback is allowed."
            ]
          }
        ]
      }
    },
    {
      "id": "psm-tooltrace-engineering-issue-lookup-before-link",
      "bot": "PSM Ops Hermes Bot",
      "surface": "slack",
      "lane": "tool-trace",
      "input": "@PS WEE is there a home page ticket in KER? If yes, link it to PCO-146",
      "setup": {
        "stub_tools": true
      },
      "expected_tool_trace": {
        "must_call": [
          "find_engineering_issue",
          "link_pco_to_engineering_issue"
        ],
        "must_not_call": [
          "create_ps_wee_intake_ticket",
          "draft_pco_task"
        ],
        "argument_shape": {
          "find_engineering_issue.project_keys": [
            "KER"
          ],
          "safe_fields_only": true,
          "ambiguous_results_require_user_choice": true
        }
      },
      "expected_answer_contract": {
        "must_include": [
          "Source: Jira",
          "Confidence:"
        ]
      },
      "forbidden_behavior": [
        "answer that PS WEE cannot search KER",
        "use Slack history as KER source of truth",
        "use memory as KER source of truth",
        "expose engineering issue descriptions, comments, or attachments"
      ],
      "grade_notes": "Natural-language KER lookup uses read-only Jira engineering search before linking; exact KER keys still link directly.",
      "assertions": {
        "source_files": [
          {
            "path": "skills/psm-ops-bot/SKILL.md",
            "must_contain": [
              "call read-only `find_engineering_issue` first",
              "If multiple plausible matches are returned, ask the user to choose"
            ]
          },
          {
            "path": "runtime/mcp/psm_jira_server.py",
            "must_contain": [
              "def find_engineering_issue",
              "ENGINEERING_SEARCH_SAFE_FIELDS"
            ]
          }
        ]
      }
    },
    {
      "id": "psm-answer-contract-ticket-created-fixture",
      "bot": "PSM Ops Hermes Bot",
      "surface": "slack",
      "lane": "answer-contract",
      "input": "stub: create_ps_wee_intake_ticket returned answer.slack_reply",
      "setup": {
        "stub_output": "ps_wee_ticket_created"
      },
      "expected_tool_trace": {
        "must_call": [
          "create_ps_wee_intake_ticket"
        ]
      },
      "expected_answer_contract": {
        "must_include": [
          "Source:",
          "Scope:",
          "Confidence: verified",
          "Caveat:"
        ]
      },
      "forbidden_behavior": [
        "rewrite Jira Slack link syntax",
        "raw Slack transcript",
        "raw C360 source pack"
      ],
      "grade_notes": "If the Jira tool returns answer.slack_reply, paste it first exactly, then add labelled source/scope/confidence/caveat.",
      "assertions": {
        "answer_fixture": {
          "output": "Created PCO ticket: <https://staffany.atlassian.net/browse/PCO-123|PCO-123>. Please add affected outlet and expected outcome.\nSource: Jira PCO\nScope: current Slack thread; PS WEE intake ticket\nConfidence: verified\nCaveat: Ticket is needs-info until the missing fields are added in this thread."
        },
        "source_files": [
          {
            "path": "profile/SOUL.md",
            "must_contain": [
              "if the Jira tool returns `answer.slack_reply`, paste that string exactly as the first line"
            ]
          }
        ]
      }
    },
    {
      "id": "psm-live-smoke-ticket-first-intake",
      "bot": "PSM Ops Hermes Bot",
      "surface": "slack:#ps-weeman-bot-test",
      "lane": "live-smoke",
      "input": "@PS WEE create a test intake ticket from this smoke thread with dummy customer context",
      "setup": {
        "requires_live_profile": "psmopsbot",
        "requires_bot_owned_readback": true,
        "writes_allowed": "explicit_ticket_smoke_only"
      },
      "expected_tool_trace": {
        "must_call": [
          "find_ticket_by_slack_thread",
          "search_pco_tickets",
          "create_ps_wee_intake_ticket"
        ]
      },
      "expected_answer_contract": {
        "must_include": [
          "Source: Jira PCO",
          "Confidence:"
        ]
      },
      "forbidden_behavior": [
        "human-token posting",
        "Slack connector write",
        "raw transcript leakage",
        "duplicate same-thread ticket"
      ],
      "grade_notes": "Run only as an approved ticket smoke because it writes Jira. Use bot-owned Slack reply and same-thread idempotency."
    }
  ]
}
